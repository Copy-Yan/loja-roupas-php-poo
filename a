<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Games Stormy</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  /* ── Reset & Base ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #2c2c2c;
    --purple:    #7c41b1;
    --purple-lt: #af76d9;
    --blue-lt:   #8db3da;
    --cyan:      #a7eff1;
    --green:     #00bc5e;
    --pink:      #ffafdf;
    --white:     #ffffff;
    --font:      'Instrument Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--white);
    min-height: 100vh;
  }

  /* ── Utility ── */
  .sr-only { position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; }
  button, input, select { font-family: var(--font); cursor: pointer; border: none; outline: none; }

  /* ══════════════════════════════
     NAVBAR
  ══════════════════════════════ */
  .navbar {
    background: var(--purple);
    display: flex;
    align-items: center;
    padding: 0 24px;
    height: 56px;
    position: sticky;
    top: 0;
    z-index: 100;
    gap: 0;
  }

  .navbar-logo {
    width: 32px;
    height: 44px;
    margin-right: 16px;
    flex-shrink: 0;
  }
  .navbar-logo img { width: 100%; height: 100%; object-fit: contain; }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
  }

  .nav-pill {
    background: var(--purple-lt);
    border-radius: 4px;
    padding: 4px 12px;
    font-size: 13px;
    color: var(--white);
    font-weight: 400;
    transition: background .18s;
    white-space: nowrap;
  }
  .nav-pill:hover { background: #c88de8; }

  .navbar-search {
    display: flex;
    align-items: center;
    background: var(--purple-lt);
    border-radius: 4px;
    padding: 5px 10px;
    gap: 8px;
    flex: 0 0 auto;
    min-width: 180px;
  }
  .navbar-search input {
    background: transparent;
    color: var(--white);
    font-size: 13px;
    font-weight: 700;
    width: 100%;
  }
  .navbar-search input::placeholder { color: rgba(255,255,255,.65); font-weight: 400; }
  .navbar-search svg { flex-shrink: 0; }

  .navbar-icons {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: 12px;
  }
  .icon-btn {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    opacity: .85;
    transition: opacity .15s;
  }
  .icon-btn:hover { opacity: 1; }
  .avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--purple-lt);
    overflow: hidden;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }

  /* ══════════════════════════════
     PAGE ROUTER
  ══════════════════════════════ */
  .page { display: none; }
  .page.active { display: block; }

  /* ══════════════════════════════
     PAGE: HOME
  ══════════════════════════════ */
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    padding: 32px 40px;
    align-items: start;
  }

  /* Hero banner / slider */
  .hero-slider {
    background: var(--pink);
    border-radius: 15px;
    min-height: 280px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-slider-label {
    font-size: 14px;
    font-weight: 700;
    color: rgba(0,0,0,.55);
    text-align: center;
    padding: 20px;
  }
  .hero-slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,.35);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    font-size: 18px;
    color: #444;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s;
  }
  .hero-slider-btn:hover { background: rgba(255,255,255,.6); }
  .hero-slider-btn.prev { left: 10px; }
  .hero-slider-btn.next { right: 10px; }
  .hero-page-btn {
    display: block;
    width: 100%;
    margin-top: 14px;
    background: var(--white);
    color: #000;
    border-radius: 4px;
    padding: 8px;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
    transition: background .15s;
  }
  .hero-page-btn:hover { background: #eee; }

  /* Wishlist sidebar */
  .sidebar-games {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .sidebar-game-row {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,.04);
    border-radius: 8px;
    padding: 8px;
    transition: background .15s;
    cursor: pointer;
  }
  .sidebar-game-row:hover { background: rgba(255,255,255,.09); }
  .sidebar-game-icon {
    width: 46px;
    height: 46px;
    background: var(--white);
    border-radius: 4px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #aaa;
    text-align: center;
  }
  .sidebar-game-info { flex: 1; min-width: 0; }
  .sidebar-game-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sidebar-game-price {
    background: var(--blue-lt);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    color: #1a3d5c;
    display: inline-block;
  }

  /* Section rows */
  .section { padding: 0 40px 32px; }
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .section-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
  }

  /* Category carousel */
  .categories-strip {
    background: var(--pink);
    border-radius: 15px;
    padding: 12px 36px;
    position: relative;
    overflow: hidden;
  }
  .categories-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .category-card {
    background: rgba(255,255,255,.25);
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 1.25;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 8px;
    font-size: 11px;
    font-weight: 700;
    color: #000;
    text-align: center;
    cursor: pointer;
    transition: transform .15s;
    position: relative;
  }
  .category-card:hover { transform: scale(1.03); }
  .category-card-bg {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,.15);
    backdrop-filter: blur(2px);
  }
  .category-card-label {
    position: relative;
    z-index: 1;
    background: rgba(0,0,0,.35);
    color: #fff;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
  }
  .strip-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0,0,0,.2);
    border: none;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    transition: background .15s;
  }
  .strip-arrow:hover { background: rgba(0,0,0,.4); }
  .strip-arrow.prev { left: 6px; }
  .strip-arrow.next { right: 6px; }

  /* Games row carousel */
  .games-row {
    position: relative;
  }
  .games-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .game-card {
    background: rgba(255,255,255,.06);
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    transition: transform .15s, background .15s;
  }
  .game-card:hover { transform: translateY(-3px); background: rgba(255,255,255,.1); }
  .game-card-thumb {
    width: 100%;
    aspect-ratio: 1.25;
    background: #3d3d3d;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: #888;
    text-align: center;
    padding: 6px;
  }
  .game-card-info {
    padding: 8px 10px;
  }
  .game-card-name {
    font-size: 12px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .game-card-price {
    background: #1a1a1a;
    border-radius: 4px;
    padding: 2px 7px;
    font-size: 11px;
    font-weight: 600;
    color: var(--green);
    display: inline-block;
  }
  .row-arrow {
    position: absolute;
    top: 35%;
    transform: translateY(-50%);
    background: rgba(0,0,0,.4);
    border: none;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    color: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    z-index: 2;
    transition: background .15s;
  }
  .row-arrow:hover { background: rgba(0,0,0,.7); }
  .row-arrow.prev { left: -16px; }
  .row-arrow.next { right: -16px; }

  /* For you / promo section */
  .foryou-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
  }
  .foryou-card {
    background: #3a3a3a;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    transition: transform .15s;
  }
  .foryou-card:hover { transform: translateY(-3px); }
  .foryou-thumb {
    width: 100%;
    aspect-ratio: 1.15;
    background: #444;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #999;
    text-align: center;
    padding: 8px;
  }
  .foryou-price {
    background: var(--green);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 700;
    color: #fff;
    display: inline-block;
    margin: 6px 10px 8px;
  }

  /* Footer */
  .site-footer {
    background: #1e1e1e;
    border-top: 1px solid rgba(255,255,255,.08);
    padding: 36px 40px;
    margin-top: 20px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-bottom: 28px;
  }
  .footer-col-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--purple-lt);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .footer-col-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col-links a {
    font-size: 13px;
    color: rgba(255,255,255,.6);
    text-decoration: none;
    transition: color .15s;
  }
  .footer-col-links a:hover { color: var(--white); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,.08);
    padding-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: rgba(255,255,255,.4);
  }
  .footer-logo-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-logo-wrap img { width: 28px; height: 28px; object-fit: contain; }

  /* ══════════════════════════════
     PAGE: LIBRARY (Frame 4 — jogos em destaque, mais jogados, pré-lançamentos)
  ══════════════════════════════ */
  .library-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: 24px 32px;
    position: relative;
  }
  .library-col {
    padding: 0 16px;
  }
  .library-col + .library-col {
    border-left: 1px solid rgba(255,255,255,.1);
  }
  .library-col-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--purple-lt);
  }
  .library-game-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,.06);
    cursor: pointer;
    transition: background .12s;
    border-radius: 6px;
    padding: 8px 6px;
  }
  .library-game-row:hover { background: rgba(255,255,255,.05); }
  .library-thumb {
    width: 55px;
    height: 67px;
    background: #3d3d3d;
    border-radius: 6px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    color: #666;
    text-align: center;
    overflow: hidden;
  }
  .library-game-info { flex: 1; min-width: 0; }
  .library-game-name {
    font-size: 12px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 5px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .library-game-price {
    background: var(--blue-lt);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    color: #1a3d5c;
    display: inline-block;
  }

  /* ══════════════════════════════
     PAGE: LOGIN
  ══════════════════════════════ */
  .auth-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 56px);
    padding: 32px 16px;
  }
  .auth-card {
    background: var(--purple);
    border-radius: 15px;
    padding: 36px 40px;
    width: 100%;
    max-width: 580px;
  }
  .auth-field-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--cyan);
    margin-bottom: 6px;
    display: block;
  }
  .auth-input {
    width: 100%;
    background: var(--blue-lt);
    border: none;
    border-radius: 4px;
    height: 36px;
    padding: 0 12px;
    font-size: 13px;
    color: #1a3d5c;
    font-weight: 500;
    margin-bottom: 16px;
    transition: background .15s;
  }
  .auth-input:focus { background: #9dc3ea; }
  .auth-input::placeholder { color: rgba(26,61,92,.5); }
  .auth-field-wrap { position: relative; }
  .auth-pw-toggle {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-calc(50% + 8px));
    background: var(--green);
    border: none;
    border-radius: 4px;
    width: 24px;
    height: 14px;
    color: var(--white);
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
  .auth-forgot {
    font-size: 12px;
    font-weight: 500;
    color: var(--purple);
    background: var(--blue-lt);
    border-radius: 4px;
    padding: 4px 12px;
    display: inline-block;
    margin: 0 auto 20px;
    cursor: pointer;
    transition: background .15s;
  }
  .auth-forgot:hover { background: #9dc3ea; }
  .auth-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .auth-footer-text { font-size: 13px; font-weight: 600; color: var(--white); }
  .auth-footer-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--purple);
    background: var(--blue-lt);
    border-radius: 4px;
    padding: 3px 12px;
    cursor: pointer;
    transition: background .15s;
  }
  .auth-footer-link:hover { background: #9dc3ea; }
  .auth-submit-row { display: flex; justify-content: center; margin-top: 8px; }
  .auth-submit {
    background: #5a2e8c;
    color: var(--white);
    border: none;
    border-radius: 8px;
    padding: 10px 48px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .06em;
    cursor: pointer;
    transition: background .15s;
  }
  .auth-submit:hover { background: #4a2278; }

  /* ══════════════════════════════
     PAGE: REGISTER
  ══════════════════════════════ */
  .register-card { max-width: 680px; }
  .register-date-row {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
  }
  .register-date-select {
    flex: 1;
    background: var(--blue-lt);
    border-radius: 4px;
    height: 36px;
    padding: 0 10px;
    font-size: 13px;
    color: var(--purple-lt);
    font-weight: 600;
    border: none;
    appearance: none;
    cursor: pointer;
  }
  .register-date-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--cyan);
    margin-bottom: 8px;
    display: block;
  }

  /* ══════════════════════════════
     GAME DETAIL (Frame 3 upper half)
  ══════════════════════════════ */
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 24px;
    padding: 32px 40px;
    align-items: start;
  }
  .detail-banner {
    background: var(--pink);
    border-radius: 15px;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    font-size: 14px;
    font-weight: 700;
    color: rgba(0,0,0,.5);
  }
  .detail-btn {
    position: absolute;
    bottom: 18px;
    left: 18px;
    background: var(--white);
    border: none;
    border-radius: 4px;
    padding: 7px 16px;
    font-size: 13px;
    font-weight: 700;
    color: #000;
    cursor: pointer;
    transition: background .15s;
  }
  .detail-btn:hover { background: #eee; }
  .detail-sidebar { display: flex; flex-direction: column; gap: 12px; }
  .detail-side-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border-radius: 6px;
    background: rgba(255,255,255,.04);
    cursor: pointer;
    transition: background .15s;
  }
  .detail-side-item:hover { background: rgba(255,255,255,.09); }
  .detail-side-icon {
    width: 46px;
    height: 46px;
    background: var(--white);
    border-radius: 4px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #aaa;
    text-align: center;
  }
  .detail-side-info { flex: 1; }
  .detail-side-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 4px;
  }
  .detail-side-price {
    background: var(--blue-lt);
    border-radius: 3px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    color: #1a3d5c;
    display: inline-block;
  }

  /* Active nav state */
  .nav-pill.active { background: #c88de8; font-weight: 700; }

  /* ══════════════════════════════
     ANIMATIONS
  ══════════════════════════════ */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .page.active { animation: fadeIn .25s ease; }

  /* ══════════════════════════════
     RESPONSIVE
  ══════════════════════════════ */
  @media (max-width: 900px) {
    .hero-split, .detail-layout { grid-template-columns: 1fr; }
    .categories-row, .games-strip, .foryou-strip { grid-template-columns: repeat(3, 1fr); }
    .library-cols { grid-template-columns: 1fr; }
    .library-col + .library-col { border-left: none; border-top: 1px solid rgba(255,255,255,.1); margin-top: 16px; padding-top: 16px; }
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .navbar-links .nav-pill:nth-child(n+3) { display: none; }
  }
  @media (max-width: 600px) {
    .navbar { padding: 0 12px; }
    .section, .hero-split, .detail-layout { padding-left: 16px; padding-right: 16px; }
    .categories-row, .games-strip, .foryou-strip { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: 1fr; }
    .auth-card { padding: 24px 20px; }
  }
</style>
</head>
<body>

<!-- ══════════════════════════════
     NAVBAR (shared)
══════════════════════════════ -->
<nav class="navbar" role="navigation" aria-label="Navegação principal">
  <div class="navbar-logo" aria-label="Games Stormy">
    <img src="https://www.figma.com/api/mcp/asset/1c5820f3-f782-4e3e-88cb-2cfc54ad9850" alt="Logo Stormy" />
  </div>

  <div class="navbar-links">
    <button class="nav-pill active" onclick="showPage('home')">Explorar</button>
    <button class="nav-pill" onclick="showPage('library')">Minha Biblioteca</button>
    <button class="nav-pill" onclick="showPage('about')">Sobre</button>
    <button class="nav-pill">Suporte</button>
  </div>

  <div class="navbar-search">
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
    </svg>
    <input type="text" placeholder="Pesquisar" aria-label="Pesquisar jogos" />
  </div>

