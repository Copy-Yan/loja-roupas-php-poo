══════════════════════════════ -->
<div style="position:fixed;bottom:20px;right:20px;display:flex;gap:8px;z-index:50">
  <button onclick="showPage('login')" style="background:var(--purple);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-family:var(--font);font-size:12px;font-weight:600;cursor:pointer;box-shadow:0 4px 12px rgba(0,0,0,.4)">Login</button>
  <button onclick="showPage('register')" style="background:var(--green);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-family:var(--font);font-size:12px;font-weight:600;cursor:pointer;box-shadow:0 4px 12px rgba(0,0,0,.4)">Cadastro</button>
</div>

<script>
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const target = document.getElementById('page-' + id);
    if (target) { target.classList.add('active'); window.scrollTo(0, 0); }

    // Update nav active state
    document.querySelectorAll('.nav-pill').forEach(b => b.classList.remove('active'));
    const map = { home: 0, library: 1, about: 2 };
    if (map[id] !== undefined) {
      document.querySelectorAll('.nav-pill')[map[id]]?.classList.add('active');
    }
  }

  // Password toggle
  document.querySelector('.auth-pw-toggle')?.addEventListener('click', function() {
    const input = document.getElementById('login-pw');
    if (input) input.type = input.type === 'password' ? 'text' : 'password';
  });
</script>
